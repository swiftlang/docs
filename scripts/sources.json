{
  "version": "main",
  "sources": [
    {
      "id": "swift-book",
      "type": "git",
      "repo": "https://github.com/swiftlang/swift-book.git",
      "ref": "main",
      "docc_catalog": "TSPL.docc",
      "preflight": "bin/generate-grammar"
    },
    {
      "id": "swift-stdlib",
      "type": "archive",
      "url": "https://download.swift.org/docs/main/swift_docc.zip",
      "format": "zip",
      "docc_archive_name": "Swift.doccarchive",
      "strip_availability": true
    },
    {
      "id": "swift-migration-guide",
      "type": "git",
      "repo": "https://github.com/swiftlang/swift-migration-guide.git",
      "ref": "main",
      "docc_catalog": "Guide.docc"
    },
    {
      "id": "compiler-diagnostics",
      "type": "git",
      "repo": "https://github.com/swiftlang/swift.git",
      "ref": "main",
      "docc_catalog": "userdocs/diagnostics",
      "extra_flags": ["--allow-arbitrary-catalog-directories"]
    },
    {
      "id": "swiftpm",
      "type": "git",
      "repo": "https://github.com/swiftlang/swift-package-manager.git",
      "ref": "release/6.3",
      "targets": ["PackageManagerDocs", "PackageDescription", "PackagePlugin"]
    },
    {
      "id": "swift-testing",
      "type": "git",
      "repo": "https://github.com/swiftlang/swift-testing.git",
      "ref": "release/6.3",
      "targets": ["Testing"],
      "add_docc_plugin": true
    },
    {
      "id": "docc-documentation",
      "type": "git",
      "repo": "https://github.com/swiftlang/swift-docc.git",
      "ref": "main",
      "docc_catalog": "Sources/docc/DocCDocumentation.docc"
    },
    {
      "id": "embedded-swift",
      "type": "git",
      "repo": "https://github.com/swiftlang/swift-embedded-examples.git",
      "ref": "main",
      "targets": ["EmbeddedSwift"]
    },
    {
      "id": "swift-wasm",
      "type": "git",
      "repo": "https://github.com/swiftlang/swift-for-wasm-examples.git",
      "ref": "main",
      "targets": ["WasmGuide"]
    },
    {
      "id": "server-guides",
      "type": "local",
      "path": "server-guides",
      "targets": ["ServerGuides"]
    },
    {
      "id": "swift-android",
      "type": "git",
      "repo": "https://github.com/swiftlang/swift-android-examples.git",
      "ref": "main",
      "targets": ["SwiftAndroid"]
    },
    {
      "id": "swift-server-todos-tutorial",
      "type": "git",
      "repo": "https://github.com/swiftlang/swift-server-todos-tutorial.git",
      "ref": "main",
      "docc_catalog": "SwiftServerTodos.docc"
    },
    {
      "id": "vscode-swift",
      "type": "git",
      "repo": "https://github.com/swiftlang/vscode-swift.git",
      "ref": "main",
      "docc_catalog": "userdocs/userdocs.docc"
    },
    {
      "id": "swiftly",
      "type": "git",
      "repo": "https://github.com/swiftlang/swiftly.git",
      "ref": "main",
      "targets": ["SwiftlyDocs"]
    },
    {
      "id": "swift-java",
      "type": "git",
      "repo": "https://github.com/swiftlang/swift-java.git",
      "ref": "main",
      "targets": ["SwiftJavaDocumentation"]
    }
  ]
}
